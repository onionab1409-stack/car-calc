# ============================================
# 🚗 CAR-CALC — Переменные окружения
# ============================================
# Скопируй этот файл как .env.local и заполни значения
# cp .env.example .env.local

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=              # Токен от @BotFather
TELEGRAM_ADMIN_CHAT_ID=          # ID чата/группы для уведомлений о заявках
NEXT_PUBLIC_BOT_USERNAME=        # Username бота (без @)

# --- Базы данных ---
DATABASE_URL="file:./dev.db"     # SQLite (для разработки)
# DATABASE_URL="libsql://..."    # Turso (для продакшена)

# --- Курсы валют ---
# Коррекция USDT к MoscaEx (±₽)
USDT_CORRECTION=1.50
# Спред ВТБ для KRW и CNY
VTB_SPREAD_KRW=0.00050
VTB_SPREAD_CNY=0.30

# --- AI (опционально) ---
ANTHROPIC_API_KEY=               # Если используем AI-агентов

# --- Приложение ---
NEXT_PUBLIC_APP_URL=             # URL Mini App (https://your-domain.com)
NODE_ENV=development
